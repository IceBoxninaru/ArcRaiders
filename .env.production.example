# docker compose / EC2 用のテンプレートです。
# 初回の起動確認だけなら FIREBASE_* を空欄のままにして DISABLE_FIREBASE=true で起動できます。
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
APP_ID=arcraidersmap
INITIAL_AUTH_TOKEN=
DISABLE_FIREBASE=true
